<?xml version="1.0" encoding="UTF-8" ?>
<CycloneDDS xmlns="https://cdds.io/config">
  <Domain Id="any">
    <General>
      <Interfaces>
        <NetworkInterface name="enp0s31f6"/>
      </Interfaces>
      <AllowMulticast>true</AllowMulticast>
    </General>
    <Discovery>
      <Peers>
        <!-- Route unicast packets directly to the Motion CPU and Jetson interfaces -->
        <Peer address="192.168.123.161"/>
        <Peer address="192.168.123.15"/>
        <Peer address="192.168.10.185"/>
      </Peers>
    </Discovery>
    <Tracing>
      <Verbosity>finest</Verbosity>
      <OutputFile>/tmp/cdds_thinkpad.log</OutputFile>
    </Tracing>
  </Domain>
</CycloneDDS>
