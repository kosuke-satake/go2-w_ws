<?xml version="1.0" encoding="UTF-8" ?>
<CycloneDDS xmlns="https://cdds.io/config">
  <Domain id="any">
    <General>
      <!-- Bind directly to the Thinkpad's static IP on the shared subnet -->
      <NetworkInterfaceAddress>192.168.10.99</NetworkInterfaceAddress>
      <AllowMulticast>true</AllowMulticast>
    </General>
    <Discovery>
      <Peers>
        <!-- Route unicast packets directly to the Robot's Jetson Wi-Fi IP -->
        <Peer address="192.168.10.185"/>
      </Peers>
    </Discovery>
  </Domain>
</CycloneDDS>
