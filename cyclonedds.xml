<?xml version="1.0" encoding="UTF-8" ?>
<CycloneDDS xmlns="https://cdds.io/config">
  <Domain id="any">
    <General>
      <!-- enp0s31f6 is the Thinkpad Ethernet interface connected to the robot AP -->
      <NetworkInterfaceAddress>enp0s31f6</NetworkInterfaceAddress>
      <AllowMulticast>true</AllowMulticast>
    </General>
    <Discovery>
      <Peers>
        <!-- Route unicast packets directly to the Motion CPU and Jetson -->
        <Peer address="192.168.123.161"/>
        <Peer address="192.168.123.15"/>
      </Peers>
    </Discovery>
  </Domain>
</CycloneDDS>
